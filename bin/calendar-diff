#!/usr/bin/env php
<?php declare(strict_types=1);

/**
 * @license  http://opensource.org/licenses/mit-license.php MIT
 * @link     https://github.com/nicoSWD
 * @author   Nicolas Oelgart <nico@ifsc.stream>
 */

function generate_start_list_diff(array $oldStartList, array $newStartList): string
{
    $diff = '';
    $buildAthleteKey = static function (array $athlete): string {
        return implode('|', [
            (string) ($athlete['first_name'] ?? ''),
            (string) ($athlete['last_name'] ?? ''),
            (string) ($athlete['country'] ?? ''),
        ]);
    };

    $oldLookup = [];
    foreach ($oldStartList as $athlete) {
        $oldLookup[$buildAthleteKey($athlete)] = $athlete;
    }

    $newLookup = [];
    foreach ($newStartList as $athlete) {
        $newLookup[$buildAthleteKey($athlete)] = $athlete;
    }

    foreach ($newLookup as $key => $athlete) {
        $firstName = (string) ($athlete['first_name'] ?? '');
        $lastName = (string) ($athlete['last_name'] ?? '');

        if (!isset($oldLookup[$key])) {
            $diff .= "|Added|{$firstName}|{$lastName}|---|---|" . PHP_EOL;
            continue;
        }

        $oldAthlete = $oldLookup[$key];
        $oldPhotoUrl = normalize_value($oldAthlete['photo_url'] ?? null);
        $newPhotoUrl = normalize_value($athlete['photo_url'] ?? null);

        if ($oldPhotoUrl !== $newPhotoUrl) {
            $diff .= "|Changed|{$firstName}|{$lastName}|photo_url: {$oldPhotoUrl}|photo_url: {$newPhotoUrl}|" . PHP_EOL;
        }

        $oldAthleteId = normalize_value($oldAthlete['athlete_id'] ?? null);
        $newAthleteId = normalize_value($athlete['athlete_id'] ?? null);

        if ($oldAthleteId === 'null' && $newAthleteId !== 'null') {
            $diff .= "|Changed|{$firstName}|{$lastName}|athlete_id: ---|athlete_id: {$newAthleteId}|" . PHP_EOL;
        }

        $oldInstagram = normalize_value($oldAthlete['instagram'] ?? null);
        $newInstagram = normalize_value($athlete['instagram'] ?? null);

        if ($oldInstagram !== $newInstagram) {
            $diff .= "|Changed|{$firstName}|{$lastName}|instagram: {$oldInstagram}|instagram: {$newInstagram}|" . PHP_EOL;
        }
    }

    foreach ($oldLookup as $key => $athlete) {
        $firstName = (string) ($athlete['first_name'] ?? '');
        $lastName = (string) ($athlete['last_name'] ?? '');

        if (!isset($newLookup[$key])) {
            $diff .= "|Removed|<s>{$firstName}</s>|<s>{$lastName}</s>|---|---|" . PHP_EOL;
        }
    }

    return $diff;
}

function normalize_value(mixed $value): string
{
    if (empty($value)) {
        return 'null';
    }

    if (is_array($value)) {
        $value = implode(', ', $value);
    }

    return (string) $value;
}

function find_round_by_name(array $oldRounds, string $name): ?array
{
    return array_find($oldRounds, fn (array $oldRound): bool => ((string) event_value($oldRound, 'name', '')) === $name);
}

function get_event_by_id(array $events, int $eventId): ?array
{
    return array_find($events, fn (array $event): bool => ((int) event_value($event, 'id', 0)) === $eventId);
}

function normalize_events_from_file(string $fileName): array
{
    return json_decode(file_get_contents($fileName), associative: true)['events'];
}

function event_value(array $payload, string $key, mixed $default = null): mixed
{
    if (array_key_exists($key, $payload)) {
        return $payload[$key];
    }

    return $default;
}

function generate_round_diff(array $oldRounds, array $newRounds): string
{
    $diff = '';
    $changedRounds = '';
    $addedRounds = '';
    $removedRounds = '';

    foreach ($newRounds as $newRound) {
        $roundName = (string) event_value($newRound, 'name', '');
        $oldRound = find_round_by_name($oldRounds, $roundName);

        if (!$oldRound) {
            foreach ($newRound as $value) {
                $addedRounds .= "|" . normalize_value($value);
            }

            $addedRounds .= "|" . PHP_EOL;
        } else {
            $roundDiff = '';
            foreach ($newRound as $key => $newValue) {
                if (array_key_exists($key, $oldRound)) {
                    $oldValue = $oldRound[$key];

                    if ($newValue !== $oldValue) {
                        $roundDiff .= "| 👉  |_{$key}_  |" . normalize_value($oldValue) . "|" . normalize_value($newValue) . "|" . PHP_EOL;
                    }
                } else {
                    if (normalize_value($newValue) !== 'null') {
                        $roundDiff .= "| 👉  |_{$key}_  |null|" . normalize_value($newValue) . "|" . PHP_EOL;
                    }
                }
            }

            if ($roundDiff) {
                $changedRounds .= "|  **{$roundName}** |   |   |   |" . PHP_EOL;
                $changedRounds .= $roundDiff;
            }
        }
    }

    foreach ($oldRounds as $oldRound) {
        $roundName = (string) event_value($oldRound, 'name', '');
        $newRound = find_round_by_name($newRounds, $roundName);

        if (!$newRound) {
            $removedRounds .= '|<s>' . normalize_value(event_value($oldRound, 'name')) . '</s>|<s>' . normalize_value(event_value($oldRound, 'starts_at')) . '</s>|<s>' . normalize_value(event_value($oldRound, 'ends_at')) . '</s>|' . PHP_EOL;
        }
    }

    if ($changedRounds) {
        $diff .= PHP_EOL;
        $diff .= "#### Changed Rounds" . PHP_EOL;
        $diff .= "|Round | **Key**               | **Old Value** | **New Value**   |" . PHP_EOL;
        $diff .= "|------|-----------------------|---------------|-----------------|" . PHP_EOL;
        $diff .= $changedRounds . PHP_EOL;
    }

    if ($addedRounds) {
        $diff .= "#### Added Rounds" . PHP_EOL;
        $diff .= "|" . implode('|', array_keys($newRounds[0])) . "|" . PHP_EOL;
        $diff .= "|" . str_repeat('-------------|', count($newRounds[0])) . PHP_EOL;
        $diff .= $addedRounds . PHP_EOL;
    }
    
    if ($removedRounds) {
        $diff .= PHP_EOL;
        $diff .= "#### Removed Rounds" . PHP_EOL;
        $diff .= "|Round | starts_at | ends_at |" . PHP_EOL;
        $diff .= "|------|-----------|---------|" . PHP_EOL;
        $diff .= $removedRounds . PHP_EOL . PHP_EOL;
    }

    return $diff;
}

$oldEvents = normalize_events_from_file($argv[1]);
$newEvents = normalize_events_from_file($argv[2]);

$diff = '';
$addedEvents = '';
$removedEvents = '';

foreach ($newEvents as $newEvent) {
    if (!get_event_by_id($oldEvents, (int) event_value($newEvent, 'id', 0))) {
        $addedEvents .= "### 🏆 " . normalize_value(event_value($newEvent, 'name')) . PHP_EOL;
        $addedEvents .= "|Key|Value|" . PHP_EOL;
        $addedEvents .= "|---|-----|" . PHP_EOL;

        foreach ($newEvent as $key => $value) {
            if ($key === 'rounds' || $key === 'start_list') {
                continue;
            }

            $addedEvents .= "|$key|" . normalize_value($value) ."|" . PHP_EOL;
        }

        $addedEvents .= PHP_EOL;
        $addedEvents .= "#### 🎯 Rounds:" . PHP_EOL;
        $rounds = is_array(event_value($newEvent, 'rounds', [])) ? event_value($newEvent, 'rounds', []) : [];
        $firstRound = $rounds[0] ?? [];
        if (!empty($firstRound)) {
            $addedEvents .= "|" . implode('|', array_keys($firstRound)) . "|" . PHP_EOL;
            $addedEvents .= "|" . str_repeat('-------------|', count($firstRound)) . PHP_EOL;
        }

        foreach ($rounds as $round) {
            foreach ($round as $value) {
                $addedEvents .= "|" . normalize_value($value);
            }
            $addedEvents .= "|" . PHP_EOL;
        }

        $addedEvents .= PHP_EOL;

        $startList = is_array(event_value($newEvent, 'start_list', [])) ? event_value($newEvent, 'start_list', []) : [];
        if (count($startList) > 0) {
            $addedEvents .= "#### 📋 Start List:" . PHP_EOL;
            $addedEvents .= "| " . implode(' | ', array_keys($startList[0])) . " |" . PHP_EOL;
            $addedEvents .= "| " . str_repeat(' | ', count($startList[0])) . PHP_EOL;

            foreach ($startList as $startListAthlete) {
                foreach ($startListAthlete as $value) {
                    $addedEvents .= " | " . normalize_value($value);
                }
                $addedEvents .= "|" . PHP_EOL;
            }
        }
    }
}

foreach ($oldEvents as $oldEvent) {
    if (!get_event_by_id($newEvents, (int) event_value($oldEvent, 'id', 0))) {
        $removedEvents .= "|🏆 " . normalize_value(event_value($oldEvent, 'name')) . "|---|---    |" . PHP_EOL;
        $removedEvents .= "|-------------|---------|-------|" . PHP_EOL;
        $removedEvents .= "|**Round**    |**Starts At**|**Ends At**|" . PHP_EOL;

        foreach ((array) event_value($oldEvent, 'rounds', []) as $round) {
            $removedEvents .= "|<s>" . normalize_value(event_value($round, 'name')) . "</s>|<s>" . normalize_value(event_value($round, 'starts_at')) . "</s>|<s>" . normalize_value(event_value($round, 'ends_at')) . "</s>" . PHP_EOL;
        }

        $removedEvents .= PHP_EOL;
    }
}

if ($addedEvents) {
    $diff .= "## 🎉 Added Events:" . PHP_EOL;
    $diff .= $addedEvents . PHP_EOL;
    $diff .= '<hr />' . PHP_EOL;
}

if ($removedEvents) {
    $diff .= "## 🗑️ Removed Events:" . PHP_EOL;
    $diff .= $removedEvents . PHP_EOL;
    $diff .= '<hr />' . PHP_EOL;
}

$changedEvents = '';

foreach ($newEvents as $newEvent) {
    $oldEvent = get_event_by_id($oldEvents, (int) event_value($newEvent, 'id', 0));

    if (!$oldEvent) {
        continue;
    }

    $newDiff = '';
    $roundDiff = '';
    $startListDiff = '';

    foreach ($newEvent as $key => $value) {
        if ($key === 'rounds') {
            $oldRounds = is_array(event_value($oldEvent, $key, [])) ? event_value($oldEvent, $key, []) : [];
            $newRounds = is_array($value) ? $value : [];
            $roundDiff .= generate_round_diff($oldRounds, $newRounds);
        } elseif ($key === 'start_list') {
            $oldStartList = is_array(event_value($oldEvent, $key, [])) ? event_value($oldEvent, $key, []) : [];
            $newStartList = is_array($value) ? $value : [];
            $startListDiff .= generate_start_list_diff($oldStartList, $newStartList);
        } elseif (normalize_value($value) !== normalize_value(event_value($oldEvent, $key))) {
            $newDiff .= "|$key|" . normalize_value(event_value($oldEvent, $key)) ."|" . normalize_value($value) . "|" . PHP_EOL;
        }
    }

    if ($newDiff || $roundDiff || $startListDiff) {
        $changedEvents .= "### 🏆 " . normalize_value(event_value($newEvent, 'name')) . PHP_EOL;

        if ($newDiff) {
            $changedEvents .= "| ℹ️ Event Details          | ---           | ---            |" . PHP_EOL;
            $changedEvents .= "|------------------------|---------------|----------------|" . PHP_EOL;
            $changedEvents .= "| **Key**                | **Old Value** | **New Value**  |" . PHP_EOL;
            $changedEvents .= $newDiff . PHP_EOL;
        }

        if ($roundDiff) {
            $changedEvents .= $roundDiff;
        }

        if ($startListDiff) {
            $changedEvents .= "| 📋 Start List |                 |               |                    |                   |" . PHP_EOL;
            $changedEvents .= "|---------------|-----------------|---------------|--------------------|-------------------|" . PHP_EOL;
            $changedEvents .= "| **Status**    | **First Name**  | **Last Name** | **Old Value**      | **New Value**     |" . PHP_EOL;
            $changedEvents .= $startListDiff . PHP_EOL;
        }

        $changedEvents .= PHP_EOL;
        $changedEvents .= '<hr />' . PHP_EOL;
        $changedEvents .= PHP_EOL;
    }
}

if ($changedEvents) {
    $diff .= PHP_EOL;
    $diff .= "## ✏️ Changed Events:" . PHP_EOL;
    $diff .= $changedEvents . PHP_EOL;
}

if (!$diff && $oldEvents !== $newEvents) {
    echo "Untracked changes", PHP_EOL;
    exit(0);
}

echo $diff;
